# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_DRY_RUN=false          # true = log replies instead of calling the LINE API (local dev/testing)

# AI Provider (pluggable)
AI_PROVIDER=anthropic       # anthropic | mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Database
DATABASE_URL=postgresql://linelink:linelink@localhost:5432/linelink_ai?schema=public

# Server
PORT=3000
